# Smart Data Cleaner Environment Configuration
# Copy to .env and customize for your environment

# ============ FLASK CONFIGURATION ============
FLASK_APP=server.py
FLASK_ENV=development
FLASK_DEBUG=False
SECRET_KEY=change-me-in-production-use-strong-random-key

# ============ DATABASE CONFIGURATION ============
# For development use SQLite (default: sqlite:///smart_data_cleaner.db)
# For production use PostgreSQL
DATABASE_URL=sqlite:///smart_data_cleaner.db

# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/smart_data_cleaner

# ============ SESSION STORAGE ============
# Options: filesystem, redis
SESSION_TYPE=filesystem
REDIS_URL=redis://localhost:6379/0
SESSION_LIFETIME_HOURS=24

# ============ FILE UPLOAD CONFIGURATION ============
UPLOAD_FOLDER=./uploads
MAX_FILE_SIZE_MB=50

# ============ SECURITY CONFIGURATION ============
# CORS origins (comma-separated for multiple)
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# Require HTTPS in production
REQUIRE_HTTPS=False

# ============ LOG CONFIGURATION ============
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json or text
LOG_FORMAT=json

# ============ REQUEST TIMEOUTS ============
REQUEST_TIMEOUT_SECONDS=300
FILE_PARSE_TIMEOUT_SECONDS=120

# ============ RATE LIMITING ============
# Redis URL for rate limiting storage
RATELIMIT_STORAGE_URL=redis://localhost:6379/1

# ============ ERROR TRACKING (SENTRY) ============
# Leave blank to disable Sentry
SENTRY_DSN=

# ============ AUTHENTICATION (Optional) ============
# Enable authentication (not implemented in v0.0.7)
ENABLE_AUTH=False
JWT_SECRET_KEY=change-me-secret-for-jwt

# ============ DATA RETENTION POLICY ============
# How many days to keep uploaded data
DATA_RETENTION_DAYS=30

# ============ DEVELOPMENT MODE ONLY ============
# Only use these for local development
DEBUG_LOGGING=False
TESTING=False
