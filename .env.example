# ============================================================
# Smart Data Cleaner — Environment Configuration
# Copy this file to .env for local development.
# For Render deployment, set these via:
#   Dashboard → Your Service → Environment → Environment Variables
# ============================================================

# ── FLASK CORE (REQUIRED) ───────────────────────────────────
FLASK_APP=server.py

# production | development
FLASK_ENV=production

# SECURITY: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ⚠️  MUST be set in Render env vars — server will refuse to start without this in production!
SECRET_KEY=CHANGE_ME_USE_PYTHON_SECRETS_TOKEN_HEX_32

# ── CORS (REQUIRED for Render) ───────────────────────────────
# Set this to your actual Render app URL (no trailing slash)
# Multiple origins: comma-separated
# Example: https://your-app.onrender.com,https://your-custom-domain.com
CORS_ORIGINS=https://your-app.onrender.com

# ── SESSION ─────────────────────────────────────────────────
# How long (seconds) to keep session data in memory before eviction
# Default: 7200 (2 hours). Render free tier restarts = sessions cleared anyway.
SESSION_TTL_SECONDS=7200

# ── FILE UPLOAD ─────────────────────────────────────────────
UPLOAD_FOLDER=./uploads
MAX_FILE_SIZE_MB=50

# ── LOGGING ─────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ── RATE LIMITING ───────────────────────────────────────────
# Uses in-memory storage (no Redis needed on Render free tier)
# Limits: 10/min for uploads, 5/min for execute, 30/min for exports

# ── HTTPS (Render handles TLS for you — leave False here) ────
REQUIRE_HTTPS=False

# ── REQUEST TIMEOUTS ────────────────────────────────────────
REQUEST_TIMEOUT_SECONDS=300
FILE_PARSE_TIMEOUT_SECONDS=120

# ── ERROR TRACKING (Sentry — Optional) ──────────────────────
# Leave blank to disable
SENTRY_DSN=

# ── AUTHENTICATION (Future) ─────────────────────────────────
# Not implemented in current version
ENABLE_AUTH=False

# ── LOCAL DEVELOPMENT ONLY ──────────────────────────────────
# NEVER set FLASK_DEBUG=true in production!
FLASK_DEBUG=False


# ============ FLASK CONFIGURATION ============
FLASK_APP=server.py
FLASK_ENV=development
FLASK_DEBUG=False
SECRET_KEY=change-me-in-production-use-strong-random-key

# ============ DATABASE CONFIGURATION ============
# For development use SQLite (default: sqlite:///smart_data_cleaner.db)
# For production use PostgreSQL
DATABASE_URL=sqlite:///smart_data_cleaner.db

# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/smart_data_cleaner

# ============ SESSION STORAGE ============
# Options: filesystem, redis
SESSION_TYPE=filesystem
REDIS_URL=redis://localhost:6379/0
SESSION_LIFETIME_HOURS=24

# ============ FILE UPLOAD CONFIGURATION ============
UPLOAD_FOLDER=./uploads
MAX_FILE_SIZE_MB=50

# ============ SECURITY CONFIGURATION ============
# CORS origins (comma-separated for multiple)
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# Require HTTPS in production
REQUIRE_HTTPS=False

# ============ LOG CONFIGURATION ============
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json or text
LOG_FORMAT=json

# ============ REQUEST TIMEOUTS ============
REQUEST_TIMEOUT_SECONDS=300
FILE_PARSE_TIMEOUT_SECONDS=120

# ============ RATE LIMITING ============
# Redis URL for rate limiting storage
RATELIMIT_STORAGE_URL=redis://localhost:6379/1

# ============ ERROR TRACKING (SENTRY) ============
# Leave blank to disable Sentry
SENTRY_DSN=

# ============ AUTHENTICATION (Optional) ============
# Enable authentication (not implemented in v0.0.7)
ENABLE_AUTH=False
JWT_SECRET_KEY=change-me-secret-for-jwt

# ============ DATA RETENTION POLICY ============
# How many days to keep uploaded data
DATA_RETENTION_DAYS=30

# ============ DEVELOPMENT MODE ONLY ============
# Only use these for local development
DEBUG_LOGGING=False
TESTING=False
