# ─── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ─── Virtual Environments ────────────────────────────────
venv/
.venv/
env/
ENV/

# ─── Environment / Secrets ───────────────────────────────
.env
# Keep .env.example in the repo — it's a template, not secrets

# ─── Uploaded user files (runtime only, never commit) ────
SmartCleaner/web/uploads/*
web/uploads/*
# But keep the directory itself so the app can write to it
!SmartCleaner/web/uploads/.gitkeep
!web/uploads/.gitkeep
!SmartCleaner/web/uploads/audit_exports/.gitkeep
!SmartCleaner/web/uploads/review_store/.gitkeep

# ─── Test / cache ────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.egg-info/
dist/
build/

# ─── OS generated ────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── IDE ─────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Logs ────────────────────────────────────────────────
# Ignore runtime log files everywhere EXCEPT the inputs/ demo folder
*.log
!inputs/*.log
!inputs/*.txt

# ─── Unused / Retired Files ──────────────────────────────
unwanter folder/
